# ============================================================
# Local development defaults — copy to .env
# TODO: Replace ALL values below before deploying to production.
# ============================================================

# --- Database (PostgreSQL) ---
# TODO(prod): Use a managed database (e.g., Cloud SQL) with strong credentials.
JOBS_DB_NAME=jobs
JOBS_DB_USER=jobs
JOBS_DB_PASSWORD=jobs

# --- Django ---
# TODO(prod): Generate a unique secret key:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
JOBS_SECRET_KEY=insecure-local-dev-key-change-me
# TODO(prod): Set to False.
JOBS_DEBUG=True

# --- Logging ---
# TODO(prod): Set JOBS_ENV=prod, JOBS_LOG_FORMAT=json, JOBS_LOG_LEVEL=WARNING
JOBS_ENV=dev
JOBS_LOG_LEVEL=INFO
JOBS_LOG_FORMAT=text
